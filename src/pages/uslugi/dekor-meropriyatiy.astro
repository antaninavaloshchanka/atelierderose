---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import eventDecor from '../../assets/images/services/event-decor.jpg';
import event01 from '../../assets/images/portfolio/events/event-01.jpg';
import event02 from '../../assets/images/portfolio/events/event-02.jpg';

const breadcrumbs = [
  { name: 'Главная', url: '/' },
  { name: 'Услуги', url: '/#services' },
  { name: 'Декор мероприятий', url: '/uslugi/dekor-meropriyatiy' },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<BaseLayout
  title="Декор мероприятий живыми цветами в Гомеле | Atelier de Rose"
  description="Оформление мероприятий живыми цветами в Гомеле — дни рождения, корпоративы, юбилеи. Цветочные композиции, арки, фотозоны. Декоратор Atelier de Rose."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="text-sm text-charcoal-light mb-8">
        {breadcrumbs.map((crumb, i) => (
          <span>
            {i > 0 && <span class="mx-1">/</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-sage-dark transition-colors">{crumb.name}</a>
            ) : (
              <span class="text-charcoal">{crumb.name}</span>
            )}
          </span>
        ))}
      </nav>

      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl mb-6">Декор мероприятий живыми цветами в Гомеле</h1>

      <div class="mb-10">
        <Image
          src={eventDecor}
          alt="Декор мероприятия живыми цветами — арки и композиции, Гомель"
          class="w-full rounded-sm aspect-[16/7] object-cover"
        />
      </div>

      <div class="space-y-6 text-charcoal-light leading-relaxed mb-12">
        <p>
          Живые цветы превращают любое мероприятие в событие. Будь то день рождения в ресторане,
          корпоратив в лофте или юбилей в банкетном зале — цветочное оформление задаёт настроение
          и создаёт атмосферу праздника с первых минут.
        </p>
        <p>
          Я работаю с мероприятиями любого формата и масштаба в Гомеле и области. Подберу цветы
          и стиль декора под тематику вашего праздника, площадку и бюджет.
        </p>

        <h2 class="font-heading text-2xl text-charcoal pt-4">Какие мероприятия оформляю</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Дни рождения и юбилеи</li>
          <li>Корпоративные мероприятия и презентации</li>
          <li>Выпускные вечера</li>
          <li>Детские праздники</li>
          <li>Романтические ужины и предложения руки и сердца</li>
          <li>Фотосессии и съёмки</li>
        </ul>

        <h2 class="font-heading text-2xl text-charcoal pt-4">Что входит в услугу</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Консультация по стилистике и подбору цветов</li>
          <li>Разработка концепции оформления под площадку</li>
          <li>Цветочные композиции на столы</li>
          <li>Оформление входной группы или welcome-зоны</li>
          <li>Фотозоны и декоративные инсталляции</li>
          <li>Монтаж и демонтаж на площадке</li>
        </ul>

        <h2 class="font-heading text-2xl text-charcoal pt-4">Стоимость</h2>
        <p>
          Минимальный заказ на оформление мероприятия — от 300 BYN. Стоимость зависит от количества
          зон декора, выбора цветов и масштаба мероприятия. Рассчитаю точную цену после обсуждения деталей.
        </p>
      </div>

      <!-- Portfolio examples -->
      <h2 class="font-heading text-2xl mb-6">Примеры оформления</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
        <Image src={event01} alt="Цветочная арка для оформления мероприятия, декор Гомель" class="w-full aspect-[3/4] object-cover rounded-sm" />
        <Image src={event02} alt="Декоративная арка из живых цветов для праздника, Гомель" class="w-full aspect-[3/4] object-cover rounded-sm" />
      </div>

      <!-- CTA -->
      <div class="text-center bg-white p-10 rounded-sm border border-charcoal/10">
        <p class="font-heading text-2xl mb-4">Планируете мероприятие?</p>
        <p class="text-charcoal-light mb-6">Расскажите о формате — предложу оформление под ваш бюджет</p>
        <a
          href="/#contact"
          class="inline-block px-10 py-4 bg-sage text-white text-sm uppercase tracking-[0.15em] hover:bg-sage-dark transition-colors rounded-sm"
        >
          Оставить заявку
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
