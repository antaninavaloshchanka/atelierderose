---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const breadcrumbs = [
  { name: 'Главная', url: `${base}/` },
  { name: 'Блог', url: `${base}/blog/` },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('ru-RU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Блог о свадебной флористике | Atelier de Rose"
  description="Статьи о свадебной флористике в Гомеле: советы по выбору цветов, разбор стоимости, тренды декора и подготовка к свадьбе."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="text-sm text-charcoal-light mb-8">
        {breadcrumbs.map((crumb, i) => (
          <span>
            {i > 0 && <span class="mx-1">/</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url} class="hover:text-sage-dark transition-colors">{crumb.name}</a>
            ) : (
              <span class="text-charcoal">{crumb.name}</span>
            )}
          </span>
        ))}
      </nav>

      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl mb-10">Блог</h1>

      <div class="space-y-8">
        {posts.map((post) => (
          <article class="border-b border-charcoal/10 pb-8">
            <a href={`${base}/blog/${post.id}/`} class="group block">
              <h2 class="font-heading text-xl sm:text-2xl mb-2 group-hover:text-sage-dark transition-colors">
                {post.data.title}
              </h2>
              <time class="text-sm text-charcoal-light block mb-3" datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              <p class="text-charcoal-light leading-relaxed">{post.data.description}</p>
            </a>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs px-2 py-1 bg-sage/10 text-sage-dark rounded-sm">{tag}</span>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-charcoal-light text-center py-12">Статьи скоро появятся</p>
      )}
    </div>
  </section>
</BaseLayout>
