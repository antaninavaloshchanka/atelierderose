---
import siteData from '../data/site.json';
---

<section id="contact" class="py-20 sm:py-28 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 reveal">
      <p class="text-sage-dark uppercase tracking-[0.2em] text-sm mb-4">Контакты</p>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl">Свяжитесь со мной</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
      <!-- Contact info -->
      <div class="reveal space-y-8">
        <div>
          <h3 class="font-heading text-xl mb-4">Давайте обсудим ваше торжество</h3>
          <p class="text-charcoal-light leading-relaxed">
            Напишите мне, и мы вместе придумаем идеальное оформление для вашего
            особого дня. Отвечаю обычно в течение нескольких часов.
          </p>
        </div>

        <div class="space-y-4">
          <!-- Location -->
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Местоположение</p>
              <p class="font-medium">{siteData.location}</p>
            </div>
          </div>

          <!-- Instagram -->
          <a href={siteData.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0 group-hover:bg-sage/20 transition-colors">
              <svg class="w-5 h-5 text-sage-dark" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Instagram</p>
              <p class="font-medium group-hover:text-sage-dark transition-colors">{siteData.instagramHandle}</p>
            </div>
          </a>

          <!-- Telegram -->
          <a href={siteData.telegram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0 group-hover:bg-sage/20 transition-colors">
              <svg class="w-5 h-5 text-sage-dark" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Telegram</p>
              <p class="font-medium group-hover:text-sage-dark transition-colors">{siteData.instagramHandle}</p>
            </div>
          </a>

          <!-- Working hours -->
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Время работы</p>
              <p class="font-medium">{siteData.workingHours}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <div class="reveal">
        <form id="contact-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm text-charcoal-light mb-1.5">Ваше имя</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 bg-white border border-charcoal/15 rounded-sm focus:outline-none focus:border-sage transition-colors text-sm"
              placeholder="Анна"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm text-charcoal-light mb-1.5">Телефон или Telegram</label>
            <input
              type="text"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-3 bg-white border border-charcoal/15 rounded-sm focus:outline-none focus:border-sage transition-colors text-sm"
              placeholder="+375 29 123 45 67"
            />
          </div>

          <div>
            <label for="date" class="block text-sm text-charcoal-light mb-1.5">Дата мероприятия</label>
            <input
              type="date"
              id="date"
              name="date"
              class="w-full px-4 py-3 bg-white border border-charcoal/15 rounded-sm focus:outline-none focus:border-sage transition-colors text-sm"
            />
          </div>

          <div>
            <label for="event-type" class="block text-sm text-charcoal-light mb-1.5">Тип мероприятия</label>
            <select
              id="event-type"
              name="event-type"
              class="w-full px-4 py-3 bg-white border border-charcoal/15 rounded-sm focus:outline-none focus:border-sage transition-colors text-sm"
            >
              <option value="">Выберите тип</option>
              <option value="wedding">Свадьба</option>
              <option value="birthday">День рождения</option>
              <option value="corporate">Корпоратив</option>
              <option value="photozone">Фотозона</option>
              <option value="other">Другое</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm text-charcoal-light mb-1.5">Сообщение</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full px-4 py-3 bg-white border border-charcoal/15 rounded-sm focus:outline-none focus:border-sage transition-colors text-sm resize-none"
              placeholder="Расскажите о вашем мероприятии..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-4 bg-sage text-white text-sm uppercase tracking-[0.15em] hover:bg-sage-dark transition-colors duration-300 rounded-sm"
          >
            Отправить заявку
          </button>

          <p id="form-status" class="text-center text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Отправка...';

    try {
      const res = await fetch(`${import.meta.env.BASE_URL}api/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          phone: data.get('phone'),
          date: data.get('date') || '',
          eventType: data.get('event-type') || '',
          message: data.get('message') || '',
        }),
      });

      if (!res.ok) throw new Error();

      status.textContent = 'Заявка отправлена! Я свяжусь с вами в ближайшее время.';
      status.className = 'text-center text-sm text-sage-dark';
      form.reset();
    } catch {
      status.textContent = 'Ошибка отправки. Напишите мне в Telegram напрямую.';
      status.className = 'text-center text-sm text-dusty-rose-dark';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Отправить заявку';
    }
  });
</script>
