---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPortfolio = await getCollection('portfolio');
const sorted = allPortfolio.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'all', label: 'Все' },
  { id: 'weddings', label: 'Свадьбы' },
  { id: 'bouquets', label: 'Букеты' },
  { id: 'events', label: 'Мероприятия' },
  { id: 'photozones', label: 'Фотозоны' },
];

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/**/*.{svg,jpg,jpeg,png,webp}',
  { eager: true }
);
---

<section id="portfolio" class="py-20 sm:py-28 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12 reveal">
      <p class="text-sage-dark uppercase tracking-[0.2em] text-sm mb-4">Портфолио</p>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl">Наши работы</h2>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap justify-center gap-3 mb-12 reveal">
      {categories.map((cat) => (
        <button
          class="filter-btn px-5 py-2 text-sm uppercase tracking-widest border border-charcoal/20 rounded-sm transition-all duration-300 hover:bg-charcoal hover:text-white data-[active]:bg-charcoal data-[active]:text-white"
          data-filter={cat.id}
          data-active={cat.id === 'all' ? '' : undefined}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Portfolio grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 reveal" id="portfolio-grid">
      {sorted.map((item) => {
        const imagePath = `/src/assets/images/portfolio/${item.data.category}/${item.id.split('/').pop()}.svg`;
        const imageModule = images[imagePath];
        return imageModule ? (
          <div
            class="portfolio-item break-inside-avoid mb-4 group relative overflow-hidden rounded-sm"
            data-category={item.data.category}
          >
            <Image
              src={imageModule.default}
              alt={item.data.title}
              class="w-full transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-300 flex items-end">
              <div class="p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                <h3 class="font-heading text-lg text-white">{item.data.title}</h3>
                {item.data.description && (
                  <p class="text-white/80 text-sm mt-1">{item.data.description}</p>
                )}
              </div>
            </div>
          </div>
        ) : null;
      })}
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.portfolio-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach((b) => b.removeAttribute('data-active'));
      btn.setAttribute('data-active', '');

      items.forEach((item) => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
