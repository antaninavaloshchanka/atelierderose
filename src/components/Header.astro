---
import siteData from '../data/site.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: '#services', label: 'Услуги' },
  { href: '#portfolio', label: 'Портфолио' },
  { href: '#about', label: 'О нас' },
  { href: '#pricing', label: 'Стоимость' },
  { href: `${base}/blog/`, label: 'Блог' },
  { href: '#contact', label: 'Контакты' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-20">
    <!-- Logo -->
    <a href={`${base}/`} class="font-heading text-2xl tracking-wide text-white header-scrolled:text-charcoal transition-colors duration-300">
      {siteData.brand}
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm uppercase tracking-widest text-white/90 hover:text-white header-scrolled:text-charcoal-light header-scrolled:hover:text-charcoal transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden relative z-50 w-10 h-10 flex items-center justify-center"
      aria-label="Открыть меню"
    >
      <div class="menu-icon space-y-1.5">
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
      </div>
    </button>
  </div>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-cream/98 z-40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <nav class="flex flex-col items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link font-heading text-3xl text-charcoal hover:text-sage-dark transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const menuToggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const menuSpans = menuToggle.querySelectorAll('.menu-icon span');
  const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-link');
  let isMenuOpen = false;

  // Scroll-aware header
  const updateHeader = () => {
    if (window.scrollY > 50) {
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'scrolled');
      menuSpans.forEach(s => s.classList.replace('bg-white', 'bg-charcoal'));
    } else if (!isMenuOpen) {
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'scrolled');
      menuSpans.forEach(s => s.classList.replace('bg-charcoal', 'bg-white'));
    }
  };
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100');
      menuSpans[0].classList.add('rotate-45', 'translate-y-2', '!bg-charcoal');
      menuSpans[1].classList.add('opacity-0');
      menuSpans[2].classList.add('-rotate-45', '-translate-y-2', '!bg-charcoal');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100');
      menuSpans[0].classList.remove('rotate-45', 'translate-y-2', '!bg-charcoal');
      menuSpans[1].classList.remove('opacity-0');
      menuSpans[2].classList.remove('-rotate-45', '-translate-y-2', '!bg-charcoal');
      document.body.style.overflow = '';
      updateHeader();
    }
  };

  menuToggle.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', () => {
    if (isMenuOpen) toggleMenu();
  }));
</script>

<style>
  .scrolled a:not(.mobile-nav-link):not([href^="#"]):not(:first-child) {
    color: var(--color-charcoal-light);
  }
  .scrolled a:not(.mobile-nav-link):not([href^="#"]):not(:first-child):hover {
    color: var(--color-charcoal);
  }
  .scrolled a[href^="#"]:not(.mobile-nav-link) {
    color: var(--color-charcoal-light);
  }
  .scrolled a[href^="#"]:not(.mobile-nav-link):hover {
    color: var(--color-charcoal);
  }
  .scrolled > div > a:first-child {
    color: var(--color-charcoal);
  }
</style>
