# Telegram Bot for contact form (server-side only, never exposed to client)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Analytics & Webmaster verification (client-side, PUBLIC_ prefix required)
# Yandex.Metrika counter ID (create at https://metrika.yandex.ru/)
PUBLIC_YANDEX_METRIKA_ID=
# Yandex.Webmaster verification tag (https://webmaster.yandex.ru/)
PUBLIC_YANDEX_VERIFICATION=
# Google Search Console verification tag (https://search.google.com/search-console)
PUBLIC_GOOGLE_VERIFICATION=
